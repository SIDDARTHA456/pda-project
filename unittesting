        self.assertEqual(len(formatted), 5)
        self.assertIn(":", formatted)

    def test_database_integration(self):
        """
        Proves data flows from the Python DataFrame
        into the SQL database correctly.
        """
        test_df = pd.DataFrame([{
            "Flight_No": "TEST999",
            "Departure_Time": "12:00",
            "Arrival_Time": "14:00",
            "Prev_Flight_Delayed": 0,
            "Current_Is_Delayed": 1
        }])

        conn = sqlite3.connect("test_integration.db")
        test_df.to_sql("temp_table", conn, if_exists="replace", index=False)

        check_df = pd.read_sql("SELECT Flight_No FROM temp_table WHERE Flight_No='TEST999'", conn)
        conn.close()

        self.assertEqual(check_df.iloc[0]['Flight_No'], "TEST999")

