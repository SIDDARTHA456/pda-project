import unittest
import sqlite3
import pandas as pd

# 1. THE TEST SUITE
class TestFlightPipeline(unittest.TestCase):

    def test_delay_feature_extraction(self):
        """
        Tests if the 15-minute (900s) threshold correctly
        identifies a delayed flight (1) vs on-time (0).
        """
        
        sched_a, real_a = 1711800000, 1711801200
        result_a = 1 if (real_a - sched_a) > 900 else 0

        sched_b, real_b = 1711800000, 1711800300
        result_b = 1 if (real_b - sched_b) > 900 else 0

        self.assertEqual(result_a, 1, "Should flag 20 min as Delayed")
        self.assertEqual(result_b, 0, "Should flag 5 min as On-Time")

